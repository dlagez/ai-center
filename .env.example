# AI中台 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# LiteLLM Proxy
MODEL_GATEWAY_BASE_URL=http://litellm-proxy:4000
MODEL_GATEWAY_API_KEY=change-me
MODEL_GATEWAY_TIMEOUT_MS=60000
MODEL_GATEWAY_ENABLE_PUBLIC_PROXY=true
MODEL_GATEWAY_ENABLE_DIRECT_FALLBACK=true
MODEL_GATEWAY_DEFAULT_LOGICAL_MODEL=chat_default
MODEL_GATEWAY_DEFAULT_PUBLIC_MODEL=public-chat-default

# Direct exception models
PRIVATE_LLM_BASE_URL=
PRIVATE_LLM_API_KEY=
PRIVATE_LLM_MODEL=
PRIVATE_LLM_LOGICAL_MODEL=private_sensitive_backup

# Embedding runtime
EMBEDDING_DEFAULT_LOGICAL_MODEL=embedding_default
EMBEDDING_DEFAULT_PUBLIC_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_MS=60000
EMBEDDING_BATCH_SIZE=32
EMBEDDING_ENABLE_PUBLIC_PROXY=true
EMBEDDING_ENABLE_DIRECT_FALLBACK=true

# Direct exception embedding models
PRIVATE_EMBEDDING_BASE_URL=
PRIVATE_EMBEDDING_API_KEY=
PRIVATE_EMBEDDING_MODEL=
PRIVATE_EMBEDDING_LOGICAL_MODEL=private_embedding_backup

# OCR runtime
OCR_DEFAULT_PROVIDER=aliyun_ocr
# Optional route overrides:
# OCR_DEFAULT_LAYOUT_PROVIDER=internal_ocr
# OCR_DEFAULT_TEXT_PROVIDER=internal_text_ocr
OCR_TIMEOUT_MS=60000
OCR_ENABLE_LAYOUT=false
OCR_PDF_BATCH_ENABLED=true
OCR_PDF_BATCH_PAGES=10
OCR_PDF_BATCH_MIN_TOTAL_PAGES=11
OCR_PDF_BATCH_MAX_RETRIES=2
OCR_PDF_BATCH_RETRY_DELAY_MS=500

# Aliyun OCR
ALIYUN_OCR_BASE_URL=
ALIYUN_OCR_API_KEY=
ALIYUN_OCR_APP_CODE=

# Internal OCR
INTERNAL_OCR_BASE_URL=
INTERNAL_OCR_API_KEY=

# Internal text OCR
INTERNAL_TEXT_OCR_BASE_URL=
INTERNAL_TEXT_OCR_API_KEY=
INTERNAL_TEXT_OCR_MODEL=paddleocr_v5

# Document parse runtime
DOCUMENT_PARSE_CACHE_DIR=data/document_parse_cache
DOCUMENT_PARSE_ENABLE_CACHE=true
DOCUMENT_PARSE_DOWNLOAD_TIMEOUT_MS=60000

# Chunking runtime
CHUNKING_DEFAULT_POLICY_NAME=default
CHUNKING_MAX_CHARS=1200
CHUNKING_OVERLAP_CHARS=150
CHUNKING_SPLIT_BY_HEADING=true
CHUNKING_SPLIT_BY_PARAGRAPH=true
CHUNKING_KEEP_HEADING_PREFIX=true

# Vector store runtime
VECTOR_STORE_PROVIDER=qdrant
VECTOR_STORE_TIMEOUT_MS=60000
VECTOR_STORE_DEFAULT_METRIC=cosine
VECTOR_STORE_COLLECTION_PREFIX=kb_
VECTOR_STORE_LOCAL_DIR=data/vector_store

# Qdrant
# Development mode: use embedded Qdrant via SDK, no standalone Qdrant service required
QDRANT_LOCAL_MODE=true
QDRANT_LOCAL_PATH=data/qdrant_local

# External Qdrant service / Qdrant Cloud
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=false
QDRANT_HTTPS=false

# LangSmith tracing / evaluation
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=ai-center-default-dev
LANGSMITH_WORKSPACE_ID=
APP_LANGSMITH_ENABLED=false
APP_LANGSMITH_PROJECT_RAG=ai-center-rag-dev
APP_LANGSMITH_PROJECT_INGEST=ai-center-ingest-dev
APP_LANGSMITH_PROJECT_EVAL=ai-center-eval-dev
APP_LANGSMITH_SAMPLE_RATE=1.0
APP_LANGSMITH_MAX_TEXT_CHARS=4000
APP_LANGSMITH_CAPTURE_RETRIEVED_TEXT=true
APP_LANGSMITH_CAPTURE_PROMPTS=true
APP_LANGSMITH_REDACT_PII=false
APP_LANGSMITH_OTEL_ENABLED=false
APP_LANGSMITH_OTEL_ONLY=false
